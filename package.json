{
  "name": "e-commerce-client",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:e-commerce-client": "node dist/e-commerce-client/server/server.mjs",
    "tailwind-init": "tailwindcss init"
  },
  "prettier": {
